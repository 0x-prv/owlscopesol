# Helius RPC/DAS API key used only by server modules.
HELIUS_API_KEY=your_helius_api_key_here

# Groq explanation layer. If GROQ_API_KEY is absent, OwlScope uses deterministic fallback copy.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Public Supabase project URL plus server-only service role key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
